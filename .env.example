# Anthropic (https://console.anthropic.com → API Keys)
# Used for AI Verdict on briefing cards. Without this, a static fallback is shown.
ANTHROPIC_API_KEY=your_key

# News API (https://newsapi.org — free tier available)
NEWS_API_KEY=your_key

# Reddit API (https://www.reddit.com/prefs/apps → create script app)
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=MarketPulse/1.0

# Stocktwits (https://api.stocktwits.com/developers)
STOCKTWITS_ACCESS_TOKEN=your_token
