# Anthropic (https://console.anthropic.com → API Keys)
# Powers the AI Verdict on ticker briefing cards. Without this, a static fallback is shown.
ANTHROPIC_API_KEY=your_key

# News is always free — RSS feeds from Google News, Yahoo Finance, CNBC, MarketWatch.
# No API key needed.

# Reddit and Stocktwits are optional legacy sources. The pipeline skips them
# automatically if these keys are not set. News RSS is the primary source.
# REDDIT_CLIENT_ID=your_client_id
# REDDIT_CLIENT_SECRET=your_client_secret
# STOCKTWITS_ACCESS_TOKEN=your_token
